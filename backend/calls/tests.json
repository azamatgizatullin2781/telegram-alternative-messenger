{
  "tests": [
    {
      "name": "Get history without token",
      "method": "GET",
      "path": "/?action=history",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Get incoming without token",
      "method": "GET",
      "path": "/?action=incoming",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Initiate call without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "initiate", "callee_id": 1, "call_type": "audio"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Clear history without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "clear_history"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}
