{
  "tests": [
    {
      "name": "Get user without token",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Register — missing fields",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "ab", "display_name": "", "password": "123"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "testuser_wc01", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Update profile without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "update_profile", "display_name": "New Name"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Change password without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "change_password", "current_password": "old", "new_password": "newpass1"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Recover account — missing fields",
      "method": "POST",
      "path": "/",
      "body": {"action": "recover_account", "username": "someone"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "Ping online without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "ping_online"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}